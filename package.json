{
  "name": "subscription-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev --workspace @subscription-tracker/api\" \"npm run dev --workspace @subscription-tracker/web\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @subscription-tracker/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @subscription-tracker/api",
    "prisma:deploy": "npm run prisma:deploy --workspace @subscription-tracker/api",
    "docker:up": "docker compose up"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "concurrently": "^8.2.2"
  }
}
